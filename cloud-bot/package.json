{
  "name": "belita-skin-match-cloud-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "regression:audit": "tsx ./scripts/regression-audit.ts",
    "eval:promptfoo": "npx promptfoo@latest eval -c ./promptfoo/promptfooconfig.yaml -o ./promptfoo/results.json",
    "beta:gate": "npm run typecheck && npm run regression:audit && npm run eval:promptfoo"
  },
  "dependencies": {
    "@libsql/client": "0.17.2",
    "@upstash/redis": "1.37.0",
    "grammy": "1.41.1",
    "hono": "4.12.9"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "wrangler": "4.78.0"
  }
}
