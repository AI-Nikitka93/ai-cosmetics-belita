{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "WebWorker"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["./worker-configuration.d.ts", "node"]
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "promptfoo/providers/**/*.ts", "worker-configuration.d.ts"]
}
